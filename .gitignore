## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono Auto Generated Files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
build/
builds/
[Bb]in/
[Oo]bj/

# Visual Studio 2015 cache/options directory
.vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
*.nunit.xml

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/

# Visual Studio profiler
*.psess
*.vsp
*.vspx

# Visual Studio Trace Files
*.e2e

# TFS 2012 Local Workspace
$tf/

# Guidance Automation Toolkit
*.gpState

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# TeamCity
_TeamCity*

# DotCover
*.dotCover

# AxoCover
*.axod

# Visual Studio code coverage results
*.coverage
*.coveragexml

# NCrunch
*.ncrunch*
*.DotSettings.user

# MightyMoose
*.mm.*

# Web workbench (Collaboration and templates)
*.WebWorkBench*

# InstallShield output folder
[Ee]xpress/

# DocProject files
*.docstates

# Click-Once directory
publish/

# Publish Web Output
*.Publish.xml

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if necessary however generally it should be included.
#!**/[Pp]ackages/repositories.config

# NuGet v3's project.json files
project.lock.json
project.fragment.lock.json

# NuGet Packages
packages/*
!packages/build/
!packages/repositories.config

# Microsoft Azure Build Artifacts
csx/
*.build.csdef

# Microsoft Azure Emulator
ecf/
rcf/

# Windows Azure Storage Emulator
WAStorageEmulator*

# Windows Azure Build Artifacts
^csx/
^*.build.csdef

# Visual Studio cache files
*.cache

# Others
*.dbmdl
*.bak
*.Backup
*.BLOB
*.pdb
*.mdb
*.dyn
data/

# SQL Server files
*.mdf
*.ldf

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_DeploymentState

# Microsoft Fakes
FakesAssemblies/

# GhostDoc
*.GhostDoc.xml

# JetBrains Rider
.idea/
*.sln.iml

# Rider local history
.idea/**/localHistory

# User-specific files generated by Visual Studio
*.suo
*.user
*.userosscache
*.sln.docstates

# Auto generated files
Generated
auto-generated/

# VS Code directories
.vscode/

# Visual Studio temp files
*.tmp
*.temp
*.log

# Web artifacts
*.vsix
*.nupkg

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# npm package lock files
package-lock.json

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env

# Visual Studio 2022
.vs/

# Rider persist and caches
.idea/
*.sln.iml

# Local History for Rider
.idea/**/localHistory
